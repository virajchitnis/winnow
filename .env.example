# Winnow configuration.
#
# These values SEED the defaults on first boot. Once Winnow is running, the
# operational settings (poll frequency, confidence threshold, model, privacy
# mode, spend cap, etc.) are edited live from the dashboard Settings tab and
# stored in the database — the DB value wins over the env value.
#
# Copy to .env and fill in. NEVER commit your real .env.

# --- Required secrets ---------------------------------------------------------
# Fastmail API token. Create at: Settings -> Privacy & Security -> Manage API
# tokens. Required scopes: Mail (read/write), Submission, Sieve.
FASTMAIL_TOKEN=fmu1-your-token-here

# Anthropic API key (https://console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Dashboard login. Generate the hash with:  winnow hashpw
APP_PASSWORD_HASH=$2a$12$replace-with-output-of-winnow-hashpw

# Random secret used to sign session cookies. Generate e.g.:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-32-bytes-of-random-hex

# --- Storage ------------------------------------------------------------------
# Path to the SQLite database file (mounted on a Docker volume in production).
WINNOW_DB=/data/winnow.db

# --- Server -------------------------------------------------------------------
# Address the dashboard binds to (kept local; reached via Tailscale / the
# cloudflared sidecar — never published directly to a public interface).
WINNOW_LISTEN=0.0.0.0:8080

# --- Seed defaults (editable later in the dashboard) --------------------------
DRY_RUN=true
TZ=UTC
DIGEST_HOUR=7
POLL_INTERVAL=15m
CONFIDENCE_THRESHOLD=0.75
LLM_DAILY_CAP=2000
ANTHROPIC_MODEL=claude-haiku-4-5
# snippet | subject_sender  (how much of each email is sent to the LLM)
PRIVACY_MODE=snippet

# --- Cloudflare Access (only needed if exposing via the Cloudflare Tunnel) ----
# When set, requests arriving via the tunnel must carry a valid
# Cf-Access-Jwt-Assertion header matching this team domain + audience.
# Leave blank to disable tunnel JWT verification (Tailscale-only deployments).
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
