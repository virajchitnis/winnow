# Deploy target for deploy.sh. Copy to .env.deploy (gitignored) and fill in.
# Your real server details must NEVER be committed.

# SSH host (hostname or user@host). Key-based auth assumed.
DEPLOY_HOST=user@your-server.example.com

# Optional explicit user (if not embedded in DEPLOY_HOST).
DEPLOY_USER=

# Absolute path on the server where the repo/compose project lives.
DEPLOY_PATH=/opt/winnow

# Transport: "rsync" to copy the working tree, or "git" to `git pull` on the
# server (requires the repo pushed to a remote the server can reach).
DEPLOY_TRANSPORT=rsync
